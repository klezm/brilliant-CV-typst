{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "brilliant-cv Metadata Schema",
  "type": "object",
  "properties": {
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "Value must match folder suffix; i.e 'zh' -> './modules_zh'"
    },
    "layout": {
      "type": "object",
      "properties": {
        "awesome_color": {
          "type": "string",
          "description": "Optional values: skyblue, red, nephritis, concrete, darknight. You can also use a custom color by hex code i.e. '#1E90FF'",
          "default": "skyblue",
          "pattern": "^(skyblue|red|nephritis|concrete|darknight|#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))$"
        },
        "color": {
          "type": "object",
          "properties": {
            "highlight": {
              "type": "object",
              "properties": {
                "sections": {
                  "type": "boolean",
                  "description": "If set to true the first 'section_letter_count' letter in the section titles will be highlighted.",
                  "default": true
                },
                "section_hr": {
                  "type": "boolean",
                  "description": "If set to true the horizontal line of the section will be highlighted too.",
                  "default": false
                },
                "section_letter_count": {
                  "type": "integer",
                  "description": "Number of the letters in the beginning of the section title to be highlighted.",
                  "default": 999
                },
                "header_info": {
                  "type": "boolean",
                  "description": "Highlight personal information in the header",
                  "default": true
                },
                "header_quote": {
                  "type": "boolean",
                  "description": "Highlight header quote",
                  "default": true
                }
              },
              "required": ["sections"]
            }
          }
        },
        "before_section_skip": {
          "type": "string",
          "description": "Spacing before sections",
          "default": "1pt",
          "pattern": "^[0-9]+pt$"
        },
        "before_entry_skip": {
          "type": "string",
          "description": "Spacing before entries",
          "default": "1pt",
          "pattern": "^[0-9]+pt$"
        },
        "before_entry_description_skip": {
          "type": "string",
          "description": "Spacing before entry descriptions",
          "default": "1pt",
          "pattern": "^[0-9]+pt$"
        },
        "paper_size" : {
          "type": "string",
          "description": "Sets paper size and standard marigins, Optional values: us-letter. Default is a4.",
          "default": "a4",
          "pattern": "^(a4|us-letter|#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))$"
        },
        "fonts": {
          "type": "object",
          "properties": {
            "regular_fonts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "header_font": {
              "type": "string",
              "default": "Roboto"
            }
          }
        },
        "header": {
          "type": "object",
          "properties": {
            "header_align": {
              "type": "string",
              "description": "Optional values: left, center, right",
              "default": "center",
              "enum": ["left", "center", "right"]
            },
            "display_profile_photo": {
              "type": "boolean",
              "description": "Display profile photo or not",
              "default": true
            },
            "photo_right": {
              "type": "boolean",
              "description": "Display profile photo on the right or left",
              "default": true
            },
            "photo_height": {
              "type": "string",
              "description": "height of profile photo (e.g. 3.6cm, auto)",
              "default": "13%",
              "pattern": "^auto|[0-9]+(.[0-9]*)?(pt|mm|cm|in|em|%|fr)$"
            }
          },
          "required": ["header_align", "display_profile_photo", "photo_right", "photo_height"]
        },
        "footer": {
          "type": "boolean",
          "description": "Display footer or not",
          "default": true
        },
        "header_quote": {
          "type": "boolean",
          "description": "Display header quote or not",
          "default": true
        },
        "entry": {
          "type": "object",
          "properties": {
            "display_entry_society_first": {
              "type": "boolean",
              "description": "Display company in bold or position in bold",
              "default": true
            },
            "display_logo": {
              "type": "boolean",
              "description": "Display organisation logo or not",
              "default": true
            }
          },
          "required": ["display_entry_society_first", "display_logo"]
        }
      },
      "required": ["awesome_color", "before_section_skip", "before_entry_skip", "before_entry_description_skip", "header", "entry"]
    },
    "inject": {
      "type": "object",
      "properties": {
        "inject_ai_prompt": {
          "type": "boolean",
          "description": "Inject AI prompt or not",
          "default": false
        },
        "inject_keywords": {
          "type": "boolean",
          "description": "Inject keywords or not",
          "default": true
        },
        "injected_keywords_list": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["inject_ai_prompt", "inject_keywords", "injected_keywords_list"]
    },
    "personal": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "info": {
          "type": "object",
          "properties": {
            "github": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "linkedin": {
              "type": "string"
            },
            "gitlab": {
              "type": "string"
            },
            "homepage": {
              "type": "string"
            },
            "orcid": {
              "type": "string"
            },
            "researchgate": {
              "type": "string"
            },
            "extraInfo": {
              "type": "string"
            },
            "custom": {
              "type": "object",
              "patternProperties": {
                "^custom-[0-9]+$": {
                  "type": "object",
                  "properties": {
                    "awesomeIcon": {
                      "type": "string"
                    },
                    "text": {
                      "type": "string"
                    },
                    "link": {
                      "type": "string"
                    }
                  },
                  "required": ["awesomeIcon", "text", "link"]
                }
              },
              "additionalProperties": false
            }
          }
        }
      },
      "required": ["first_name", "last_name", "info"]
    },
    "lang": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}$": {
          "type": "object",
          "properties": {
            "header_quote": {
              "type": "string"
            },
            "cv_footer": {
              "type": "string"
            },
            "letter_footer": {
              "type": "string"
            }
          },
          "required": ["header_quote", "cv_footer", "letter_footer"]
        },
        "^non_latin$": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "font": {
              "type": "string"
            }
          },
          "required": ["name", "font"]
        }
      }
    },
    "package":{
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "import_path": {
              "type": "string",
              "description": "Path to the package. Example: '@preview/brilliant-cv:2.0.4'. If you want to use the package locally, set the path to '/lib.typ'",
              "default": "@preview/brilliant-cv:2.0.4"
            }
          },
          "required": ["import_path"]
        }
      }
    }
  },
  "required": ["language", "layout", "inject", "personal", "lang", "package"]
}
